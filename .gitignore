# Vendor: strip embedded git repos and non-essential files.
# We only need src/ from each grammar for the build.
vendor/tree-sitter-core/
vendor/**/.git/
vendor/tree-sitter-python/binding*
vendor/tree-sitter-python/bindings/
vendor/tree-sitter-python/test/
vendor/tree-sitter-python/corpus/
vendor/tree-sitter-python/examples/
vendor/tree-sitter-python/script/
vendor/tree-sitter-python/.github/
vendor/tree-sitter-python/setup.py
vendor/tree-sitter-python/Cargo.*
vendor/tree-sitter-python/Makefile
vendor/tree-sitter-python/package.json
vendor/tree-sitter-python/package-lock.json
vendor/tree-sitter-python/pyproject.toml
vendor/tree-sitter-python/*.md
vendor/tree-sitter-python/.editorconfig
vendor/tree-sitter-python/.gitignore
vendor/tree-sitter-python/.gitattributes
vendor/tree-sitter-javascript/binding*
vendor/tree-sitter-javascript/bindings/
vendor/tree-sitter-javascript/test/
vendor/tree-sitter-javascript/corpus/
vendor/tree-sitter-javascript/examples/
vendor/tree-sitter-javascript/script/
vendor/tree-sitter-javascript/.github/
vendor/tree-sitter-javascript/Cargo.*
vendor/tree-sitter-javascript/Makefile
vendor/tree-sitter-javascript/package.json
vendor/tree-sitter-javascript/package-lock.json
vendor/tree-sitter-javascript/*.md
vendor/tree-sitter-javascript/.editorconfig
vendor/tree-sitter-javascript/.gitignore
vendor/tree-sitter-javascript/.gitattributes
